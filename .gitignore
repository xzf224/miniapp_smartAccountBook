# ── 微信开发者工具 ────────────────────────────────────────
# 私有配置（含个人 appid、编译选项等，不应共享）
project.private.config.json

# 开发者工具自动生成的缓存/临时目录
.idea/
.DS_Store
*.log

# ── Node / 云函数依赖 ─────────────────────────────────────
node_modules/
cloudfunctions/**/node_modules/

# ── 测试覆盖率报告（本地生成，无需提交）──────────────────
coverage/

# ── TypeScript 编译产物 ───────────────────────────────────
# 小程序开发者工具会在 miniprogram/ 下生成 .js 编译结果
# 如果使用 tsc 单独编译，忽略输出目录；若直接用 DevTools 编译则不需要此行
# dist/

# ── 敏感信息 / 密钥 ──────────────────────────────────────
# 若后续将 API Key 抽到单独配置文件，在此处忽略
# config.secret.ts
# .env
# .env.local
