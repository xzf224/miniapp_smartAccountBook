:host {
  display: block;
  width: 100%;
}

.category-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  width: 100%;
  padding: 8rpx 16rpx 16rpx;
}

.grid-item {
  width: 16.6666%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  background: transparent;
  border-radius: 0;
  border-bottom: 3rpx solid transparent;
  box-sizing: border-box;
}

.grid-item.active {
  border-bottom-color: var(--color-primary);
}

.grid-item.active .name {
  color: var(--color-primary);
  font-weight: 600;
}

.icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.emoji {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.name {
  font-size: 18rpx;
  color: var(--color-text-primary);
  text-align: center;
  white-space: normal;
  line-height: 1.3;
  width: 100%;
}
