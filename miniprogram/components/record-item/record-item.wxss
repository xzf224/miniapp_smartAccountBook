:host {
  display: block;
}

.record-item {
  padding: 22rpx 32rpx;
  background: var(--color-bg-card);
  display: flex;
  flex-direction: row;
  align-items: center;
}

.icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.category {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.note {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.amount {
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: -0.5rpx;
}
