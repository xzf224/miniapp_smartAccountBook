/* ===== 页面根节点 ===== */
page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ===== 页面容器 ===== */
.page-container {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: #f5f6f8;
  overflow: hidden;
}

/* ===== 可滚动结果区域 ===== */
.results-area {
  flex: 1;
  height: 0;
  padding: 32rpx 24rpx 24rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx 40rpx;
}

.empty-icon-img {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.35;
}

.empty-title {
  font-size: 32rpx;
  color: #555;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #aaa;
}

/* 识别原文卡片 */
.raw-text-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.raw-text-label {
  font-size: 22rpx;
  color: #aaa;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.raw-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.65;
}

/* 草稿条目 */
.draft-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.draft-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.draft-icon-text {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.draft-content {
  flex: 1;
  min-width: 0;
}

.draft-category {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
}

.draft-note-input {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  width: 100%;
  height: 40rpx;
}

.draft-amount-area {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.draft-currency {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  margin-right: 2rpx;
}

.draft-amount-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  width: 120rpx;
  text-align: right;
}

.remove-icon {
  font-size: 40rpx;
  color: #ccc;
  padding: 4rpx 0 4rpx 20rpx;
  line-height: 1;
  flex-shrink: 0;
}

.input-ph {
  color: #ccc;
}

/* 保存按钮 */
.save-all-btn {
  background: #07c160;
  border-radius: 56rpx;
  text-align: center;
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  margin: 8rpx 0 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
}

/* ===== 底部固定面板 ===== */
.bottom-panel {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 28rpx 40rpx 240rpx;
  border-top: 1rpx solid #eee;
}

/* 状态行 */
.status-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 20rpx;
}

.status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 7rpx;
  margin-right: 12rpx;
  transition: background 0.3s;
}

.dot-ready {
  background: #bbb;
}

.dot-recording {
  background: #ff4757;
  animation: pulse-dot 1s ease-in-out infinite;
}

.dot-translating {
  background: #ffa502;
}

.status-label {
  font-size: 26rpx;
  color: #888;
}

/* 按住提示 */
.mic-hint {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 36rpx;
}

/* 麦克风按钮 */
.mic-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(7, 193, 96, 0.45);
  transition: transform 0.12s ease, background 0.2s ease, box-shadow 0.2s ease;
  margin-bottom: 32rpx;
}

.mic-btn.mic-recording {
  background: #ff4757;
  box-shadow: 0 10rpx 40rpx rgba(255, 71, 87, 0.45);
  transform: scale(1.1);
}

.mic-btn.mic-translating {
  background: #ccc;
  box-shadow: none;
  transform: scale(1);
}

.mic-icon-img {
  width: 80rpx;
  height: 80rpx;
}

/* 免责声明 */
.disclaimer {
  font-size: 22rpx;
  color: #bbb;
  text-align: center;
}

/* 动画 */
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}
