/* ===== 页面根节点 ===== */
page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ===== 页面容器 ===== */
.page-container {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: #f5f6f8;
  overflow: hidden;
}

/* ===== 可滚动结果区域 ===== */
.results-area {
  flex: 1;
  height: 0;
  padding: 32rpx 24rpx 24rpx;
  box-sizing: border-box;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx 40rpx;
}

.empty-icon-img {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.35;
}

.empty-icon-emoji {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.35;
}

.empty-title {
  font-size: 32rpx;
  color: #555;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.empty-hint {
  font-size: 26rpx;
  color: #aaa;
}

/* 图片预览卡片 */
.preview-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.preview-img {
  width: 100%;
  display: block;
}

.scan-action-btn {
  margin: 24rpx;
  background: #07c160;
  border-radius: 56rpx;
  text-align: center;
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
}

.scan-btn-disabled {
  background: #ccc;
  box-shadow: none;
}

/* 草稿条目 */
.draft-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.draft-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.draft-icon-text {
  font-size: 48rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.draft-content {
  flex: 1;
  min-width: 0;
}

.draft-pickers {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.picker-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
}

.type-tag {
  background: rgba(7, 193, 96, 0.12);
  color: #07c160;
}

.cat-tag {
  background: #f5f6f8;
  color: #888;
  border: 1rpx solid #e8e8e8;
}

.draft-note-input {
  font-size: 24rpx;
  color: #888;
  width: 100%;
  height: 40rpx;
}

.draft-amount-area {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.draft-currency {
  font-size: 26rpx;
  font-weight: 700;
  color: #333;
  margin-right: 2rpx;
}

.draft-amount-input {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  width: 120rpx;
  text-align: right;
}

.remove-icon {
  font-size: 40rpx;
  color: #ccc;
  padding: 4rpx 0 4rpx 20rpx;
  line-height: 1;
  flex-shrink: 0;
}

.input-ph {
  color: #ccc;
}

/* 保存按钮 */
.save-all-btn {
  background: #07c160;
  border-radius: 56rpx;
  text-align: center;
  padding: 26rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: #fff;
  margin: 8rpx 0 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
}

/* ===== 底部固定面板 ===== */
.bottom-panel {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 28rpx 40rpx 56rpx;
  border-top: 1rpx solid #eee;
}

/* 操作行 */
.action-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-bottom: 28rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-btn.action-disabled {
  opacity: 0.4;
}

.action-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(7, 193, 96, 0.4);
  margin-bottom: 16rpx;
}

.action-icon {
  width: 52rpx;
  height: 52rpx;
}

.action-label {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.action-divider {
  width: 1rpx;
  height: 80rpx;
  background: #eee;
  margin: 0 48rpx;
  flex-shrink: 0;
}

/* 免责声明 */
.disclaimer {
  font-size: 22rpx;
  color: #bbb;
  text-align: center;
}
