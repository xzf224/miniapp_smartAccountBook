<navigation-bar title="定期账单" back="{{true}}" />
<scroll-view scroll-y class="page-body">

  <view class="empty-state" wx:if="{{rules.length === 0}}">
    <image class="empty-icon" src="/images/schedule.png" mode="aspectFit" />
    <text class="empty-text">还没有定期账单规则</text>
    <text class="empty-sub">点击下方按钮添加，如每月房租、话费等</text>
  </view>

  <view wx:else>
    <view class="rule-card" wx:for="{{rules}}" wx:key="id" wx:for-item="rule">
      <view class="rule-main" data-id="{{rule.id}}" bind:tap="onEditRule">
        <view class="rule-left">
          <view class="rule-title-row">
            <text class="rule-name">{{rule.name}}</text>
            <text class="rule-freq">{{rule.frequencyLabel}}</text>
          </view>
          <view class="rule-meta">
            <text class="rule-type {{rule.type === '支出' ? 'type-expense' : 'type-income'}}">{{rule.type}}</text>
            <text class="rule-category">{{rule.category}}</text>
            <text wx:if="{{rule.note}}" class="rule-note">· {{rule.note}}</text>
          </view>
        </view>
        <view class="rule-right">
          <text class="rule-amount {{rule.type === '支出' ? 'amount-expense' : 'amount-income'}}">¥{{rule.amountYuan}}</text>
        </view>
      </view>
      <view class="rule-footer">
        <view class="toggle-area" data-id="{{rule.id}}" bind:tap="onToggleRule">
          <view class="toggle-track {{rule.enabled ? 'active' : ''}}">
            <view class="toggle-thumb"></view>
          </view>
          <text class="toggle-label">{{rule.enabled ? '已启用' : '已暂停'}}</text>
        </view>
        <view class="delete-btn" data-id="{{rule.id}}" bind:tap="onDeleteRule">删除</view>
      </view>
    </view>
  </view>

  <view class="add-btn" bind:tap="onAddRule">＋ 新增定期账单</view>

  <view style="height: 60rpx;"></view>
</scroll-view>
