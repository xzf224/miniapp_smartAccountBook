.page-root {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-body {
  flex: 1;
  height: 0;
  background: var(--color-bg-page);
}

.default-badge {
  background: #f0f0f0;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #999;
}

.cat-item {
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.cat-item:last-child {
  border-bottom: none;
}

.cat-name {
  font-size: 30rpx;
  color: #333;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}

.delete-icon {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

/* Add section */
.add-card {
  margin-top: 0;
}

.add-title {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.add-row {
  align-items: center;
  background: transparent;
  border-bottom: 1rpx solid var(--color-border);
  padding: 0;
}

.add-input {
  height: 80rpx;
  font-size: 30rpx;
  color: #333;
}

.add-btn {
  padding: 14rpx 28rpx;
  background: transparent;
}

.add-btn-text {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}
