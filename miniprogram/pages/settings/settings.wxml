<navigation-bar title="设置" back="{{false}}" />
<scroll-view scroll-y class="page-body">

  <view class="section-header">账单管理</view>
  <view class="card settings-group">
    <view class="settings-item flex-row" bind:tap="onBudgetSetting">
      <image class="item-icon-img" src="/images/budget.png" mode="aspectFit" />
      <text class="item-label flex-1">预算设置</text>
      <text class="item-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="settings-item flex-row" bind:tap="onCategoryManage">
      <image class="item-icon-img" src="/images/category.png" mode="aspectFit" />
      <text class="item-label flex-1">类别管理</text>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <view class="section-header">数据</view>
  <view class="card settings-group">
    <view class="settings-item flex-row" bind:tap="onExportData">
      <image class="item-icon-img" src="/images/export.png" mode="aspectFit" />
      <text class="item-label flex-1">导出账单 (CSV)</text>
      <text class="item-arrow">›</text>
    </view>
    <view class="divider"></view>
    <view class="settings-item flex-row danger" bind:tap="onClearAll">
      <image class="item-icon-img" src="/images/clear.png" mode="aspectFit" />
      <text class="item-label flex-1">清空所有数据</text>
      <text class="item-arrow">›</text>
    </view>
  </view>

  <view class="section-header">分享</view>
  <view class="card settings-group">
    <button class="settings-item flex-row share-btn" open-type="share">
      <image class="item-icon-img" src="/images/share.png" mode="aspectFit" />
      <text class="item-label flex-1">分享给朋友</text>
      <text class="item-arrow">›</text>
    </button>
  </view>

  <view class="app-info">
    <text class="app-name">极简小帐</text>
    <text class="app-version">{{version}}</text>
  </view>

  <view style="height: 40rpx;"></view>
</scroll-view>
